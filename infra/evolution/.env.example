# Postgres (servico evolution-postgres no compose)
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=change-me-local-only

# Evolution API — copie AUTHENTICATION_API_KEY para backend/.env como EVOLUTION_API_KEY
SERVER_URL=http://localhost:8080
AUTHENTICATION_API_KEY=change-me-gap-evolution-local

# Banco de dados (persistencia de instancias e mensagens)
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change-me-local-only@evolution-postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=gapselling_evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# Redis (cache)
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=gapselling_evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# Sessoes WhatsApp — nao apagar instancia da memoria ao desconectar
DEL_INSTANCE=false

# Logs uteis para debug de webhook/QR
LOG_LEVEL=ERROR,WARN,INFO,WEBHOOKS
LOG_BAILEYS=error

# WhatsApp Web — versao compativel (atualize se QR parar de gerar)
# Lista: https://wppconnect-team.github.io/whatsapp-versions/ (sem sufixo -alpha)
CONFIG_SESSION_PHONE_VERSION=2.3000.1040300918
CONFIG_SESSION_PHONE_CLIENT=Chrome
CONFIG_SESSION_PHONE_NAME=Chrome

# Preferir JID com telefone real em webhooks (Evolution 2.3+)
WPP_LID_MODE=false
