# Supabase (service role - NUNCA expor no frontend)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT validation (mesmo projeto Supabase Auth)
SUPABASE_JWT_SECRET=

# App
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://gapselling-platform.vercel.app

# Integracoes
OPENAI_API_KEY=
N8N_WEBHOOK_SECRET=

# WhatsApp - Evolution API (F3)
# Stack local: infra/evolution/ — ver Docs/EVOLUTION_LOCAL.md
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-gap-evolution-local
# URL que a Evolution usa para chamar webhooks (container -> host no Docker Desktop)
API_PUBLIC_URL=http://host.docker.internal:8000
# Deixe vazio no teste local; Evolution nao envia X-Webhook-Secret por padrao
WHATSAPP_WEBHOOK_SECRET=
CAMPAIGN_SEND_RATE_PER_MINUTE=30
